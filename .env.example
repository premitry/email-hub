# Salin ke .env lalu isi dengan value dari project Supabase-mu sendiri.
# JANGAN commit file .env yang sudah terisi (sudah di-ignore di .gitignore).

# --- Server-side (WAJIB) ---
SUPABASE_URL="https://project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# RAHASIA — bypass Row Level Security. Server-only, jangan pakai prefix VITE_.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- Client-side (di-embed ke bundle frontend) ---
VITE_SUPABASE_URL="https://project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
